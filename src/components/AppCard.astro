---
interface Props {
  name: string;
  description: string;
  url: string;
  bluesky?: string;
  category?: string;
  logo?: string;
}

const { name, description, url, bluesky, category, logo } = Astro.props;

// Generate a deterministic color from the app name
function appColor(n: string): string {
  let hash = 0;
  for (const ch of n) hash = ((hash << 5) - hash + ch.charCodeAt(0)) | 0;
  const hue = ((hash % 360) + 360) % 360;
  return `oklch(50% 0.13 ${hue})`;
}

const initials = name
  .split(/\s+/)
  .slice(0, 2)
  .map(w => w[0]?.toUpperCase() ?? '')
  .join('');
const logoSrc = logo?.startsWith('/') ? `${import.meta.env.BASE_URL}${logo}` : logo;
---

<article class="app-card">
  <a href={url} class="app-card__link" rel="noopener noreferrer" target="_blank">
    <div class="app-card__icon-wrap">
      {logoSrc ? (
        <img src={logoSrc} alt="" class="app-card__logo" width="40" height="40" loading="lazy" />
      ) : (
        <span class="app-card__icon" style={`background: ${appColor(name)}`} aria-hidden="true">{initials}</span>
      )}
    </div>
    <div class="app-card__body">
      <div class="app-card__header">
        <h3 class="app-card__name">{name}</h3>
        {category && <span class="badge badge--tag">{category}</span>}
      </div>
      <p class="app-card__desc">{description}</p>
    </div>
  </a>
  {bluesky && (
    <a href={bluesky} class="app-card__bsky" rel="noopener noreferrer" target="_blank" aria-label={`${name} on Bluesky`}>
      <svg width="16" height="14" viewBox="0 0 568 501" fill="currentColor" aria-hidden="true">
        <path d="M123.121 33.664C188.241 82.553 258.281 181.68 284 234.873c25.719-53.192 95.759-152.32 160.879-201.21C491.866-1.611 568-28.906 568 49.845c0 17.712-10.155 148.79-16.111 170.07-20.703 73.984-96.144 92.854-163.25 81.433 117.3 19.964 147.14 86.907 82.697 153.834-122.178 126.907-175.736-31.784-189.577-72.58-1.786-5.271-2.62-7.721-2.756-5.636-.14-2.085-.97.365-2.757 5.636-13.84 40.796-67.399 199.487-189.577 72.58C22.56 388.152 52.4 321.209 169.7 301.345c-67.106 11.42-142.547-7.45-163.25-81.433C.488 198.634-9.667 67.556-9.667 49.845c0-78.75 76.134-51.456 132.788-16.181z" />
      </svg>
    </a>
  )}
</article>

<style>
  .app-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    background: var(--color-surface-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-base);
    transition: border-color 0.15s ease;
    position: relative;
  }
  .app-card:hover {
    border-color: var(--blue-300);
  }

  .app-card__link {
    display: flex;
    gap: var(--space-md);
    text-decoration: none;
    color: inherit;
    min-width: 0;
    flex: 1;
  }

  .app-card__icon-wrap {
    flex-shrink: 0;
  }

  .app-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    color: oklch(98% 0 0);
    font-size: var(--text-xs);
    font-weight: 700;
    font-family: var(--font-body);
  }

  .app-card__logo {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    object-fit: cover;
  }

  .app-card__body {
    min-width: 0;
    flex: 1;
  }

  .app-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .app-card__name {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--neutral-900);
    line-height: var(--leading-tight);
  }

  .app-card__desc {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
    line-height: var(--leading-normal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .app-card__bsky {
    flex-shrink: 0;
    color: var(--color-primary);
    display: flex;
    padding: var(--space-xs);
    align-self: center;
  }
  .app-card__bsky:hover {
    color: var(--color-primary-hover);
  }
</style>
